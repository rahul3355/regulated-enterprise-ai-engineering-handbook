{
  "default": true,
  "MD007": { "indent": 2 },
  "MD013": { "line_length": 1000, "code_blocks": false, "tables": false },
  "MD024": { "siblings_only": true },
  "MD026": { "punctuation": ".,;:!。，；：！" },
  "MD033": { "allowed_elements": ["details", "summary", "b"] },
  "MD036": false,
  "MD041": false,
  "MD046": { "style": "fenced" },
  "no-hard-tabs": true,
  "whitespace": false
}
